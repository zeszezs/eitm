   ══════════════════════════════════════════════════════════════════════ */
.bm-cn-body { display: flex; flex-direction: column; gap: 6px; }
.bm-cn-row { display: flex; align-items: center; gap: 6px; }
.bm-cn-history { display: flex; flex-direction: column; gap: 2px; margin-top: 4px; }
