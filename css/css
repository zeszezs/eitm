/* === ClanMembersOnline === */

.bm-addon-window-clanmembers {
  overflow: hidden;
  width: 242px !important;
  min-height: 210px !important;
  max-height: 500px !important;
  /* własny chrome rysuje .bm-clanmembers-bg — zdejmij ramkę bazową */
  background: none !important;
  box-shadow: none !important;
  border-radius: 0 !important;
}

.bm-addon-window-clanmembers .bm-addon-window-body {
  padding: 0 !important;
  overflow: hidden;
}

/* własny nagłówek rysuje .bm-clanmembers-tw — generyczny mini-header zbędny */
.bm-addon-window-clanmembers .bm-addon-win-header {
  display: none;
}

.bm-clanmembers-view {
  height: 100%;
}

/* --- transparent window frame --- */
.bm-clanmembers-tw {
  position: relative;
  border-radius: 7px;
  text-shadow: 1px 1px 1px #000;
  color: #fff;
  height: 100%;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  overflow: hidden;
}

.bm-clanmembers-bg {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  margin: 2px;
  border-radius: 4px;
  z-index: -1;
  pointer-events: none;
  background: rgba(0, 0, 0, 0.7);
  box-shadow: 0 0 0 1px #010101, 0 0 0 2px var(--bm-brand), 0 0 0 3px #0c0d0d, 2px 2px 3px 3px rgba(12, 13, 13, 0.4);
}

/* --- header label --- */
.bm-clanmembers-header-label {
  text-align: center;
  height: 28px;
  display: inline-block;
  margin: 0 auto;
  position: relative;
  background: none;
  box-shadow: none;
  padding: 0 12px;
  flex-shrink: 0;
}

.bm-clanmembers-header-text {
  color: #F5F5DC;
  line-height: 28px;
  text-align: center;
  font-size: 10px;
  font-weight: bold;
  white-space: nowrap;
}

/* --- count (top right) --- */
.bm-clanmembers-count {
  position: absolute;
  top: 6px;
  right: 30px;
  color: #F5F5DC;
  font-size: 10px;
  cursor: pointer;
  z-index: 1;
}

.bm-clanmembers-count:hover {
  color: #fff;
  text-decoration: underline;
}

/* --- close button (top right) --- */
.bm-clanmembers-close-decor {
  position: absolute;
  top: 4px;
  right: 4px;
  z-index: 2;
}

.bm-clanmembers-close {
  background: none;
  border: none;
  color: #c6c6c6;
  font-size: 14px;
  padding: 0;
  width: auto;
  height: auto;
  cursor: pointer;
  text-shadow: none;
  line-height: 1;
}

.bm-clanmembers-close:hover {
  color: #fff;
}

/* --- content area --- */
.bm-clanmembers-content {
  flex: 1;
  min-height: 0;
  padding: 0 5px;
  overflow: hidden;
}

.bm-clanmembers-inner {
  height: 100%;
  overflow-y: auto;
  overflow-x: hidden;
  scrollbar-width: thin;
  scrollbar-color: rgba(255, 255, 255, 0.25) transparent;
}

.bm-clanmembers-inner::-webkit-scrollbar {
  width: 8px;
}

.bm-clanmembers-inner::-webkit-scrollbar-track {
  background: transparent;
}

.bm-clanmembers-inner::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 4px;
}

/* --- spots --- */
.bm-clanmembers-spots {
  display: flex;
  flex-wrap: wrap;
  gap: 3px;
  padding-bottom: 4px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  margin-bottom: 4px;
}

.bm-clan-spot {
  display: inline-flex;
  align-items: center;
  padding: 1px 6px;
  border-radius: 3px;
  background: rgba(255, 255, 255, 0.08);
  color: #F5F5DC;
  font-size: 10px;
  font-weight: bold;
  cursor: pointer;
  user-select: none;
}

.bm-clan-spot:hover {
  background: rgba(255, 255, 255, 0.15);
  color: #fff;
}

/* --- player list --- */
.bm-clanmembers-list {
  min-height: 0;
}

.bm-clan-row {
  display: table;
  width: 100%;
  font-weight: bold;
  color: #fff;
  font-size: 10px;
  line-height: 22px;
  cursor: default;
  box-sizing: border-box;
}

.bm-clan-row:hover {
  background: rgba(255, 255, 255, 0.08);
}

.bm-clan-row.bm-clan-highlight {
  background: rgba(255, 255, 255, 0.12);
}

.bm-clan-row.bm-clan-me {
  color: #F5F5DC;
}

.bm-clan-nick {
  display: table-cell;
  vertical-align: middle;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 1px;
  cursor: pointer;
  padding-left: 3px;
}

.bm-clan-nick:hover {
  text-decoration: underline;
}

.bm-clan-prof {
  display: table-cell;
  vertical-align: middle;
  width: 20px;
  text-align: center;
  color: rgba(255, 255, 255, 0.6);
  font-weight: normal;
  font-size: 10px;
}

.bm-clan-lvl {
  display: table-cell;
  vertical-align: middle;
  width: 70px;
  text-align: right;
  padding-right: 2px;
  color: rgba(255, 255, 255, 0.7);
}

/* --- search bar --- */
.bm-clanmembers-search {
  flex-shrink: 0;
  height: 28px;
  margin: 0 5px;
  border-top: 1px solid rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 0 2px;
  box-sizing: border-box;
}

.bm-clanmembers-search-icon {
  flex-shrink: 0;
  width: 14px;
  height: 14px;
  opacity: 0.4;
  color: #fff;
}

.bm-clanmembers-search-input {
  flex: 1;
  min-width: 0;
  color: #fff;
  background: transparent;
  border: none;
  font-size: 10px;
  outline: none;
  text-shadow: 1px 1px 1px #000;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  padding: 0;
  margin: 0;
  line-height: 28px;
}

.bm-clanmembers-search-input::placeholder {
  color: rgba(255, 255, 255, 0.5);
}

/* --- empty state --- */
.bm-clanmembers-empty {
  color: #fff;
  text-align: center;
  padding-bottom: 3px;
  font-size: 10px;
}

/* --- resize handle --- */
.bm-clanmembers-resize-handle {
  flex-shrink: 0;
  height: 8px;
  cursor: ns-resize;
  position: relative;
}

.bm-clanmembers-resize-handle::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 2px;
  transform: translateX(-50%);
  width: 30px;
  height: 3px;
  border-radius: 2px;
  background: rgba(255, 255, 255, 0.25);
}

/* --- opacity toggle button (top left) --- */
.bm-clanmembers-opacity-btn {
  position: absolute;
  top: 5px;
  left: 8px;
  z-index: 2;
  cursor: pointer;
  color: #c6c6c6;
  line-height: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 14px;
  height: 14px;
  user-select: none;
}

.bm-clanmembers-opacity-btn:hover {
  color: #fff;
}

/* --- opacity levels on .bm-clanmembers-tw --- */
.bm-clanmembers-tw[data-bm-opacity-lvl="0"] .bm-clanmembers-bg {
  opacity: 1;
}

.bm-clanmembers-tw[data-bm-opacity-lvl="1"] .bm-clanmembers-bg {
  opacity: 0.75;
}

.bm-clanmembers-tw[data-bm-opacity-lvl="2"] .bm-clanmembers-bg {
  opacity: 0.5;
}

.bm-clanmembers-tw[data-bm-opacity-lvl="3"] .bm-clanmembers-bg {
  opacity: 0.25;
}

