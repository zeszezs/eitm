/* ── Floating notification alerts ──────────────────────────── */

.bm-alert-container {
  position: fixed;
  display: flex;
  flex-direction: column;
  gap: 5px;
  padding: 10px;
  z-index: 9999;
  pointer-events: none;
  max-width: min(380px, calc(100vw - 20px));
}

/* 9 position variants */
.bm-alert-container.bm-pos-tl { top: 0; left: 0; align-items: flex-start; }
.bm-alert-container.bm-pos-tc { top: 0; left: 50%; transform: translateX(-50%); align-items: center; }
.bm-alert-container.bm-pos-tr { top: 0; right: 0; align-items: flex-end; }
.bm-alert-container.bm-pos-ml { top: 50%; left: 0; transform: translateY(-50%); align-items: flex-start; }
.bm-alert-container.bm-pos-mc { top: 50%; left: 50%; transform: translate(-50%, -50%); align-items: center; }
.bm-alert-container.bm-pos-mr { top: 50%; right: 0; transform: translateY(-50%); align-items: flex-end; }
.bm-alert-container.bm-pos-bl { bottom: 0; left: 0; align-items: flex-start; flex-direction: column-reverse; }
.bm-alert-container.bm-pos-bc { bottom: 0; left: 50%; transform: translateX(-50%); align-items: center; flex-direction: column-reverse; }
.bm-alert-container.bm-pos-br { bottom: 0; right: 0; align-items: flex-end; flex-direction: column-reverse; }

.bm-alert {
  position: relative;
  overflow: hidden;
  pointer-events: auto;
  min-width: 200px;
  max-width: 360px;
  padding: 10px 14px 16px;
  border-radius: 6px;
  border: 1px solid rgba(255, 255, 255, 0.12);
  background: rgba(18, 18, 22, 0.92);
  backdrop-filter: blur(8px);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
  color: rgba(255, 255, 255, 0.88);
  font-size: 13px;
  text-align: center;
  animation: bm-alert-in 0.25s ease-out forwards;
  transition: opacity 0.35s ease;
}

.bm-alert.is-out {
  opacity: 0;
}

.bm-alert-title {
  font-weight: 600;
  font-size: 13px;
  margin-bottom: 3px;
  color: rgba(255, 255, 255, 0.95);
}

.bm-alert-body {
  font-size: 11px;
  color: rgba(255, 255, 255, 0.6);
}

.bm-alert-progress {
  position: absolute;
  bottom: 0;
  left: 0;
  height: 3px;
  width: 100%;
  background: rgba(91, 140, 201, 0.55);
  animation-name: bm-alert-progress-shrink;
  animation-timing-function: linear;
  animation-fill-mode: forwards;
}

@keyframes bm-alert-in {
  from { opacity: 0; transform: translateY(-6px) scale(0.97); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}

@keyframes bm-alert-progress-shrink {
  from { width: 100%; }
  to   { width: 0%; }
}

