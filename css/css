.bm-cci-body { display: flex; flex-direction: column; gap: 5px; }
.bm-cci-info { font-size: 9px; color: rgba(255,255,255,0.38); line-height: 1.5; padding: 2px 0; }
.bm-cci-row { display: flex; align-items: center; justify-content: space-between; gap: 8px; padding: 3px 0; }
.bm-cci-label { font-size: 10px; font-weight: 600; flex: 1; }
.bm-cci-color { width: 32px; height: 22px; border: 1px solid rgba(255,255,255,0.10); border-radius: 4px; padding: 0; cursor: pointer; background: none; }

/* ══════════════════════════════════════════════════════════════════════
