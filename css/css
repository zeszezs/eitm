/* ════════════════════════════════════════════════════════════
   LegendaryNotifier — efekty wizualne w grze
   ════════════════════════════════════════════════════════════ */
/* Map glow — pseudo-element, nigdy na samym .game-layer (box-shadow tam nie rusza niczym,
   ale trzymamy ten sam wzorzec co reszta: ciagle animacje TYLKO na pseudo-elementach). */
.game-layer.bm-leg-map-active::after {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 100;
  animation: bm-leg-pulse-map var(--bm-leg-map-speed, 0.6s) infinite alternate;
}
@keyframes bm-leg-pulse-map {
  0%   { box-shadow: inset 0 0 calc(var(--bm-leg-map-size-one, 10px) * 3) calc(var(--bm-leg-map-size-one, 10px) * 0.25) var(--bm-leg-map-color-one, transparent); }
  100% { box-shadow: inset 0 0 calc(var(--bm-leg-map-size-two, 20px) * 3) calc(var(--bm-leg-map-size-two, 20px) * 1.5) var(--bm-leg-map-color-two, transparent); }
}

/* Okno lupu — TYLKO jednorazowa animacja wejscia na realnym elemencie (ten sam co jest
   .ui-draggable w grze). Ciagly glow idzie na ::before, zeby NIGDY nie kolidowac z
   przesuwaniem okna (transform na realnym oknie = konflikt z jQuery UI draggable). */
body.bm-legendary-active .bm-leg-loot-window {
  animation: var(--bm-leg-lootwindow-animation, none) 1.5s normal 1;
}
body.bm-legendary-active .bm-leg-loot-window::before {
  content: "";
  position: absolute;
  top: -28px;
  left: -15px;
  width: calc(100% + 28px);
  height: calc(100% + 55px);
  border-radius: 10px;
  box-sizing: border-box;
  opacity: 0.75;
  z-index: -1;
  pointer-events: none;
  animation: bm-leg-pulse-window var(--bm-leg-window-speed, 0.6s) infinite alternate;
}
@keyframes bm-leg-pulse-window {
  0%   { box-shadow: 0 0 calc(var(--bm-leg-window-size-one, 10px) * 2) calc(var(--bm-leg-window-size-one, 10px) * 0.25) var(--bm-leg-window-color-one, transparent); }
  100% { box-shadow: 0 0 calc(var(--bm-leg-window-size-two, 20px) * 2) calc(var(--bm-leg-window-size-two, 20px) * 1) var(--bm-leg-window-color-two, transparent); }
}

/* Wrapper itemu — TYLKO box-shadow (glow), zero transform. Zawiera przyciski accept/decline,
   transform tu nie wchodzi w gre (psowal hitbox/drag w poprzedniej wersji). */
body.bm-legendary-active [data-bm-leg-wrapper] {
  position: relative;
  z-index: 10;
  animation: bm-leg-pulse-wrapper var(--bm-leg-wrapper-speed, 0.6s) infinite alternate;
}
@keyframes bm-leg-pulse-wrapper {
  0%   { box-shadow: 0 0 calc(var(--bm-leg-wrapper-size-one, 10px) * 1) calc(var(--bm-leg-wrapper-size-one, 10px) * 0.2) var(--bm-leg-wrapper-color-one, transparent), inset 0 0 calc(var(--bm-leg-wrapper-size-one, 10px) * 1) calc(var(--bm-leg-wrapper-size-one, 10px) * 0.2) var(--bm-leg-wrapper-color-one, transparent); }
  100% { box-shadow: 0 0 calc(var(--bm-leg-wrapper-size-two, 20px) * 1) calc(var(--bm-leg-wrapper-size-two, 20px) * 0.8) var(--bm-leg-wrapper-color-two, transparent), inset 0 0 calc(var(--bm-leg-wrapper-size-two, 20px) * 1) calc(var(--bm-leg-wrapper-size-two, 20px) * 0.8) var(--bm-leg-wrapper-color-two, transparent); }
}

body.bm-legendary-active [data-bm-leg-loot-slot] {
  animation: bm-leg-pulse-loot var(--bm-leg-loot-speed, 0.6s) infinite alternate;
}
@keyframes bm-leg-pulse-loot {
  0%   { box-shadow: 0 0 calc(var(--bm-leg-loot-size-one, 10px) * 1) calc(var(--bm-leg-loot-size-one, 10px) * 0.25) var(--bm-leg-loot-color-one, transparent); }
  100% { box-shadow: 0 0 calc(var(--bm-leg-loot-size-two, 20px) * 1) calc(var(--bm-leg-loot-size-two, 20px) * 1) var(--bm-leg-loot-color-two, transparent); }
}

body.bm-legendary-active [data-bm-leg-buttons] {
  position: relative;
  z-index: 10;
  animation: bm-leg-pulse-buttons var(--bm-leg-buttons-speed, 0.6s) infinite alternate;
}
@keyframes bm-leg-pulse-buttons {
  0%   { box-shadow: 0 0 calc(var(--bm-leg-buttons-size-one, 6px) * 1) calc(var(--bm-leg-buttons-size-one, 6px) * 0.2) var(--bm-leg-buttons-color-one, transparent), inset 0 0 calc(var(--bm-leg-buttons-size-one, 6px) * 1) calc(var(--bm-leg-buttons-size-one, 6px) * 0.2) var(--bm-leg-buttons-color-one, transparent); }
  100% { box-shadow: 0 0 calc(var(--bm-leg-buttons-size-two, 12px) * 1) calc(var(--bm-leg-buttons-size-two, 12px) * 0.4) var(--bm-leg-buttons-color-two, transparent), inset 0 0 calc(var(--bm-leg-buttons-size-two, 12px) * 1) calc(var(--bm-leg-buttons-size-two, 12px) * 0.4) var(--bm-leg-buttons-color-two, transparent); }
}

/* Animacja przedmiotu — TYLKO na samym canvas ikony (jak margoplus), pointer-events:none
   na gwarancje ze nigdy nie wejdzie w hitbox przyciskow accept/decline obok. */
body.bm-legendary-active [data-bm-leg-wrapper] canvas.icon.canvas-icon {
  animation: var(--bm-leg-item-animation, none) var(--bm-leg-item-speed, 0.6s) infinite alternate;
  pointer-events: none;
}

/* Animacje przedmiotu (transform) — 1:1 z margoplus (ai-*) */
@keyframes bm-leg-item-scaling { 0% { transform: scale(1); } 100% { transform: scale(2); } }
@keyframes bm-leg-item-bounce  { 0%, 100% { transform: translateY(0) scale(1); } 30% { transform: translateY(-20%) scale(1.05); } 50% { transform: translateY(0) scale(.95); } 70% { transform: translateY(-10%) scale(1.02); } }
@keyframes bm-leg-item-shake   { 0%, 100% { transform: translateX(0); } 20% { transform: translateX(-5px); } 40% { transform: translateX(5px); } 60% { transform: translateX(-5px); } 80% { transform: translateX(5px); } }
@keyframes bm-leg-item-flip    { 0%, 100% { transform: rotateY(0deg); } 50% { transform: rotateY(180deg); } }
@keyframes bm-leg-item-spin    { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

/* Animacje okna lupu (transform, jednorazowe) — 1:1 z margoplus (alw-*) */
@keyframes bm-leg-window-shake  { 0% { transform: translateX(0); } 15% { transform: translateX(-10px); } 30% { transform: translateX(10px); } 45% { transform: translateX(-8px); } 60% { transform: translateX(8px); } 75% { transform: translateX(-5px); } 100% { transform: translateX(0); } }
@keyframes bm-leg-window-pulse  { 0% { transform: scale(1); } 15% { transform: scale(1.2); } 30% { transform: scale(1); } 45% { transform: scale(1.15); } 60% { transform: scale(1); } 75% { transform: scale(1.1); } 100% { transform: scale(1); } }
@keyframes bm-leg-window-bounce { 0% { transform: translateY(0); } 15% { transform: translateY(-15px); } 30% { transform: translateY(0); } 45% { transform: translateY(-10px); } 60% { transform: translateY(0); } 75% { transform: translateY(-6px); } 100% { transform: translateY(0); } }

/* Deszcz efektow / confetti */
.bm-legendary-rain {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 2147483000;
  overflow: hidden;
}

.bm-legendary-rain-piece {
  position: absolute;
  top: -40px;
  font-size: 26px;
  line-height: 1;
  animation-name: bm-leg-rain-fall;
  animation-timing-function: linear;
  animation-fill-mode: forwards;
  --bm-rain-rotate: 0deg;
  text-shadow: 0 0 6px rgba(255, 215, 0, 0.6);
}

.bm-legendary-rain-piece.is-img {
  font-size: 0;
}

.bm-legendary-rain-piece.is-img img {
  display: block;
  filter: drop-shadow(0 0 6px gold);
}

@keyframes bm-leg-rain-fall {
  0%   { transform: translateY(-40px) rotate(0deg); opacity: 0; }
  10%  { opacity: 1; }
  100% { transform: translateY(110vh) rotate(var(--bm-rain-rotate)); opacity: 0.15; }
}

.bm-legendary-rain-piece.is-confetti {
  font-size: 16px;
  font-weight: 700;
  animation-name: bm-leg-confetti-fall;
}

@keyframes bm-leg-confetti-fall {
  0%   { transform: translate(0, 0) rotate(0deg); opacity: 0; }
  10%  { opacity: 1; }
  100% { transform: translate(var(--bm-confetti-dx, 0px), var(--bm-confetti-dy, -40vh)) rotate(var(--bm-rain-rotate)); opacity: 0; }
}
