  display: flex;
  align-items: center;
  gap: 6px;
  padding: 3px 5px;
  border-radius: 4px;
  background: rgba(255, 255, 255, 0.03);
  font-size: 10px;
}

.bm-ta-item-row.bm-ta-alert {
  background: rgba(255, 100, 50, 0.1);
  border: 1px solid rgba(255, 100, 50, 0.3);
}

.bm-ta-item-name {
  flex: 1;
  color: rgba(255, 255, 255, 0.75);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bm-ta-item-avg {
  color: #7ec8e3;
  font-size: 10px;
  flex-shrink: 0;
}

.bm-ta-item-diff {
  font-size: 10px;
  font-weight: 700;
  flex-shrink: 0;
}

.bm-ta-diff-up { color: #27ae60; }
.bm-ta-diff-down { color: #e74c3c; }

.bm-ta-no-items {
  color: rgba(255, 255, 255, 0.35);
  font-size: 10px;
  text-align: center;
  padding: 8px 0;
}

/* === SmartNotifier === */
.bm-addon-window-smartnotifier .bm-addon-window-body-smartnotifier {
  padding: 8px 8px 10px;
}

.bm-sn-queue {
  display: flex;
  flex-direction: column;
  gap: 4px;
  margin-bottom: 6px;
}

.bm-sn-toast {
  border-radius: 6px;
  padding: 6px 10px;
  background: rgba(126, 200, 227, 0.1);
  border-left: 3px solid #7ec8e3;
  animation: bm-sn-fade-in 0.25s ease;
}

.bm-sn-type-elite { border-left-color: #e67e22; background: rgba(230, 126, 34, 0.1); }
.bm-sn-type-legendary { border-left-color: #f1c40f; background: rgba(241, 196, 15, 0.1); }
.bm-sn-type-autoheal { border-left-color: #2ecc71; background: rgba(46, 204, 113, 0.1); }
.bm-sn-type-dropestimator { border-left-color: #9b59b6; background: rgba(155, 89, 182, 0.1); }

@keyframes bm-sn-fade-in {
  from { opacity: 0; transform: translateY(-4px); }
  to   { opacity: 1; transform: translateY(0); }
}

.bm-sn-toast-title {
  font-size: 11px;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.9);
}

.bm-sn-toast-body {
  font-size: 10px;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 2px;
}

.bm-sn-history {
  display: flex;
  flex-direction: column;
  gap: 2px;
  max-height: 160px;
  overflow-y: auto;
}

.bm-sn-hist-row {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 9px;
  padding: 2px 4px;
  border-radius: 3px;
  background: rgba(255, 255, 255, 0.02);
}

.bm-sn-hist-type {
  color: rgba(255, 255, 255, 0.3);
  font-size: 8px;
  text-transform: uppercase;
  flex-shrink: 0;
  width: 50px;
}

.bm-sn-hist-title {
  flex: 1;
  color: rgba(255, 255, 255, 0.55);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bm-sn-hist-ago {
  color: rgba(255, 255, 255, 0.2);
  flex-shrink: 0;
}

.bm-sn-empty-queue {
  color: rgba(255, 255, 255, 0.25);
  font-size: 10px;
  text-align: center;
  padding: 6px 0;
}

/* ── Headerless addon window mini-header (×close + title) ── */

.bm-addon-win-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 6px;
  padding: 6px 8px;
  border-bottom: 1px solid var(--bm-brand-dim);
  flex-shrink: 0;
  cursor: grab;
}

.bm-addon-win-header-ident {
  display: flex;
  align-items: center;
  gap: 6px;
  min-width: 0;
}

.bm-addon-win-header .bm-module-name {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.03em;
  color: rgba(255, 255, 255, 0.78);
}

.bm-addon-win-header .bm-icon-button {
  flex-shrink: 0;
  width: 22px;
  height: 22px;
  font-size: 14px;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ── Shared addon body / install-lock shell ── */

.bm-addon-body-inner {
  display: flex;
  flex-direction: column;
  gap: 5px;
}

.bm-addon-install-lock {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.bm-install-lock-title {
  font-size: 11px;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.75);
}

.bm-install-lock-desc {
  font-size: 10px;
  color: rgba(255, 255, 255, 0.38);
  line-height: 1.4;
}

.bm-addon-section-label {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.35);
}

.bm-addon-divider {
  height: 1px;
  background: rgba(255, 255, 255, 0.06);
  margin: 2px 0;
}

.bm-addon-status-msg,
.bm-addon-action-msg {
  font-size: 9px;
  color: rgba(255, 255, 255, 0.38);
  line-height: 1.4;
}

/* ══════════════════════════════════════════════════════════════════════
   Main Panel — Start tab dashboard
   ══════════════════════════════════════════════════════════════════════ */

.bm-dash {
  display: block;
  padding: 10px 12px;
}

.bm-dash-row {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 7px 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  min-height: 32px;
}

.bm-dash-row:last-of-type {
  border-bottom: none;
}

.bm-dash-key {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.28);
  min-width: 80px;
  flex-shrink: 0;
}

.bm-dash-val {
  font-size: 11px;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.82);
  flex: 1;
}

.bm-dash-of {
  font-weight: 400;
  color: rgba(255, 255, 255, 0.35);
}

.bm-dash-meta {
  font-size: 9px;
  color: rgba(255, 255, 255, 0.3);
  margin-left: auto;
  flex-shrink: 0;
}

.bm-dash-val kbd {
  font-family: inherit;
  font-size: 9px;
  padding: 2px 5px;
  border-radius: 4px;
  border: 1px solid rgba(255, 255, 255, 0.12);
  background: rgba(255, 255, 255, 0.04);
  color: rgba(255, 255, 255, 0.6);
}

.bm-dash-action {
  margin-left: auto;
  flex-shrink: 0;
  padding: 2px 8px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: var(--bm-r-sm);
  background: rgba(255, 255, 255, 0.03);
  color: rgba(255, 255, 255, 0.52);
  font-size: 9px;
  font-weight: 700;
  cursor: pointer;
  font-family: inherit;
  transition: background 0.15s, color 0.15s;
}

.bm-dash-action:hover {
  background: rgba(255, 255, 255, 0.07);
  color: rgba(255, 255, 255, 0.8);
}

.bm-dash-section-title {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.25);
  padding: 10px 0 5px;
}

.bm-dash-addon-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
}

.bm-dash-addon-chip {
  display: flex;
  align-items: center;
  gap: 5px;
  padding: 4px 8px;
  border: 1px solid rgba(255, 255, 255, 0.07);
  border-radius: var(--bm-r-sm);
  background: rgba(255, 255, 255, 0.02);
  color: rgba(255, 255, 255, 0.62);
  font-size: 10px;
  font-weight: 600;
  cursor: pointer;
  font-family: inherit;
  transition: background 0.15s, border-color 0.15s;
}

.bm-dash-addon-chip:hover {
  background: rgba(255, 255, 255, 0.06);
  border-color: rgba(255, 255, 255, 0.14);
  color: rgba(255, 255, 255, 0.88);
}

/* ══════════════════════════════════════════════════════════════════════
   Main Panel — Addon browser (two-column)
   ══════════════════════════════════════════════════════════════════════ */

.bm-panel-addon-browser {
  display: grid;
  grid-template-columns: 200px 1fr;
  flex: 1 1 auto;
  min-height: 0;
  overflow: hidden;
}

.bm-panel-addon-list {
  display: flex;
  flex-direction: column;
  border-right: 1px solid rgba(255, 255, 255, 0.06);
  overflow: hidden;
  min-height: 0;
}

.bm-panel-addon-search {
  padding: 8px 8px 6px;
  flex-shrink: 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  position: relative;
}

.bm-panel-search-clear {
  position: absolute;
  right: 14px;
  top: 50%;
  transform: translateY(-58%);
  width: 18px;
  height: 18px;
  padding: 0;
  border: none;
  border-radius: 2px;
  background: transparent;
  color: var(--bm-text-tertiary);
  font-size: 11px;
  line-height: 1;
  cursor: pointer;
}

.bm-panel-search-clear:hover {
  color: var(--bm-text-primary);
  background: var(--bm-brand-dim);
}

.bm-panel-search-input {
  width: 100%;
  box-sizing: border-box;
  padding: 5px 8px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: var(--bm-r-sm);
  background: rgba(0, 0, 0, 0.3);
  color: rgba(255, 255, 255, 0.8);
  font: inherit;
  font-size: 10px;
  outline: none;
  transition: border-color 0.15s;
}

.bm-panel-search-input::placeholder {
  color: rgba(255, 255, 255, 0.25);
}

.bm-panel-search-input:focus {
  border-color: rgba(255, 255, 255, 0.22);
}

.bm-panel-addon-rows {
  flex: 1 1 auto;
  min-height: 0;
  overflow-y: auto;
  overflow-x: hidden;
  scrollbar-width: thin;
  scrollbar-color: rgba(255, 255, 255, 0.1) transparent;
  padding: 4px 4px;
}

.bm-panel-addon-row {
  display: flex;
  align-items: center;
  gap: 7px;
  width: 100%;
  padding: 6px 8px;
  border: none;
  border-radius: var(--bm-r-sm);
  background: transparent;
  color: rgba(255, 255, 255, 0.55);
  font: inherit;
  font-size: 10px;
  text-align: left;
  cursor: pointer;
  transition: background 0.12s, color 0.12s;
}

.bm-panel-addon-row:hover {
  background: rgba(255, 255, 255, 0.05);
  color: rgba(255, 255, 255, 0.78);
}

.bm-panel-addon-row.is-active {
  background: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.92);
}

.bm-panel-addon-row-name {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 600;
}

.bm-panel-row-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  flex-shrink: 0;
}

.bm-panel-row-dot.is-on {
  background: var(--bm-success);
  box-shadow: 0 0 5px rgba(74, 222, 128, 0.4);
}

.bm-panel-addon-empty {
  padding: 10px 8px;
  font-size: 9px;
  color: rgba(255, 255, 255, 0.28);
  text-align: center;
}

/* ── Detail panel (right column) ──────────────────────── */

.bm-panel-addon-detail {
  display: flex;
  flex-direction: column;
  overflow-y: auto;
  overflow-x: hidden;
  scrollbar-width: thin;
  scrollbar-color: rgba(255, 255, 255, 0.1) transparent;
  min-height: 0;
}

.bm-panel-addon-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  font-size: 10px;
  color: rgba(255, 255, 255, 0.2);
}

.bm-panel-detail-inner {
  padding: 14px 14px 16px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.bm-panel-detail-head {
  display: flex;
  align-items: center;
  gap: 10px;
}

.bm-panel-detail-ident {
  flex: 1;
  min-width: 0;
}

.bm-panel-detail-short {
  font-size: 9px;
  color: rgba(255, 255, 255, 0.3);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-top: 1px;
}

.bm-panel-detail-desc {
  margin: 0;
  font-size: 10px;
  line-height: 1.55;
  color: rgba(255, 255, 255, 0.55);
}

.bm-panel-detail-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 3px;
}

.bm-panel-detail-tag {
  padding: 2px 6px;
  border-radius: var(--bm-r-pill);
  border: 1px solid rgba(255, 255, 255, 0.08);
  background: rgba(255, 255, 255, 0.03);
  font-size: 9px;
  color: rgba(255, 255, 255, 0.35);
  letter-spacing: 0.05em;
}

.bm-panel-detail-actions {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}

.bm-panel-install-btn {
  padding: 6px 14px;
  border-radius: var(--bm-r-sm);
  border: 1px solid rgba(74, 222, 128, 0.28);
  background: rgba(74, 222, 128, 0.1);
  color: var(--bm-success);
  font: inherit;
  font-size: 10px;
  font-weight: 700;
  cursor: pointer;
  transition: background 0.15s, border-color 0.15s;
}

.bm-panel-install-btn:hover {
  background: rgba(74, 222, 128, 0.18);
}

.bm-panel-install-btn.is-installed {
  border-color: rgba(248, 113, 113, 0.25);
  background: rgba(248, 113, 113, 0.08);
  color: var(--bm-danger);
}

.bm-panel-install-btn.is-installed:hover {
  background: rgba(248, 113, 113, 0.15);
}

.bm-panel-detail-note {
  margin: 0;
}

/* Każdy bezpośredni child panel-body rozciąga się na całą dostępną przestrzeń */
.bm-panel-body > * {
  flex: 1 1 auto;
  min-height: 0;
}

/* Online: nagłówek stały, scrolluje sama lista kart */
.bm-panel-body > .bm-users-view {
  overflow: hidden;
}

/* Taby z przewijaniem — Start, Opcje, Changelog */
.bm-panel-body > .bm-dash,
.bm-panel-body > .bm-settings-view-wrap,
.bm-panel-body > .bm-cl-shell {
  overflow-y: auto;
  overflow-x: hidden;
  overscroll-behavior: contain;
  scrollbar-width: thin;
  scrollbar-color: rgba(215, 186, 122, 0.18) transparent;
}

.bm-panel-body > .bm-cl-shell::-webkit-scrollbar {
  width: 5px;
}
.bm-panel-body > .bm-cl-shell::-webkit-scrollbar-track {
  background: transparent;
}
.bm-panel-body > .bm-cl-shell::-webkit-scrollbar-thumb {
  border-radius: 999px;
  background: rgba(215, 186, 122, 0.18);
}
.bm-panel-body > .bm-cl-shell::-webkit-scrollbar-thumb:hover {
  background: rgba(215, 186, 122, 0.32);
}

/* Addon browser wypełnia całość bez własnego scrolla (scroll jest wewnątrz kolumn) */
.bm-panel-body > .bm-panel-addon-browser {
  overflow: hidden;
}

/* ══════════════════════════════════════════════════════════════════════
   Settings tab
   ══════════════════════════════════════════════════════════════════════ */

.bm-settings-view-wrap {
  display: block;
  padding: 8px 12px 14px;
  scrollbar-width: thin;
  scrollbar-color: rgba(255, 255, 255, 0.1) transparent;
}

.bm-set-section {
  padding: 10px 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  display: flex;
  flex-direction: column;
  gap: 7px;
}

.bm-set-section:last-child {
  border-bottom: none;
}

.bm-set-section-title {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.35);
}

.bm-set-section-sub {
  font-size: 9px;
  color: rgba(255, 255, 255, 0.3);
  line-height: 1.4;
  margin-top: -4px;
}

.bm-set-row-actions {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}

/* ── Game theme selector ───────────────────────────────── */

.bm-theme-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6px;
}

.bm-theme-card {
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding: 8px;
  border: 1px solid rgba(255, 255, 255, 0.07);
  border-radius: var(--bm-r-md);
  background: rgba(255, 255, 255, 0.02);
  cursor: pointer;
  font-family: inherit;
  text-align: left;
  transition: border-color 0.15s, background 0.15s;
}

.bm-theme-card:hover {
  background: rgba(255, 255, 255, 0.05);
  border-color: rgba(255, 255, 255, 0.14);
}

.bm-theme-card.is-active {
  border-color: rgba(91, 140, 201, 0.5);
  background: rgba(91, 140, 201, 0.08);
  box-shadow: 0 0 0 1px rgba(91, 140, 201, 0.2);
}

.bm-theme-card-preview {
  height: 36px;
  border-radius: 4px;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.06);
}

.bm-theme-preview-none {
  background: linear-gradient(135deg,
    #c8a96e 0%, #b8943a 25%,
    #7a5e38 50%, #4e3820 75%,
    #2a1e10 100%);
}

.bm-theme-preview-bm-dark {
  background: linear-gradient(135deg,
    #111 0%, #1a1a1a 25%,
    #0d0d0d 50%, #222 75%,
    #0a0a0a 100%);
  position: relative;
}

.bm-theme-preview-bm-dark::after {
  content: "";
  position: absolute;
  inset: 0;
  background:
    linear-gradient(90deg, transparent 30%, rgba(48,48,48,0.4) 30%, rgba(48,48,48,0.4) 70%, transparent 70%),
    linear-gradient(180deg, rgba(30,30,30,0.6) 0%, transparent 40%);
}

.bm-theme-card-label {
  font-size: 10px;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.78);
}

.bm-theme-card-desc {
  font-size: 9px;
  color: rgba(255, 255, 255, 0.35);
  line-height: 1.3;
}

/* ── Alert position grid ───────────────────────────────── */

.bm-alert-pos-grid {
  display: flex;
  flex-direction: column;
  gap: 3px;
  align-self: flex-start;
}

.bm-alert-pos-row {
  display: flex;
  gap: 3px;
}

.bm-alert-pos-btn {
  width: 32px;
  height: 28px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: var(--bm-r-sm);
  background: rgba(255, 255, 255, 0.03);
  color: rgba(255, 255, 255, 0.45);
  font: inherit;
  font-size: 12px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.12s, color 0.12s, border-color 0.12s;
}

.bm-alert-pos-btn:hover {
  background: rgba(255, 255, 255, 0.07);
  color: rgba(255, 255, 255, 0.75);
}

.bm-alert-pos-btn.is-active {
  border-color: rgba(91, 140, 201, 0.5);
  background: rgba(91, 140, 201, 0.12);
  color: rgba(255, 255, 255, 0.9);
}

/* ══════════════════════════════════════════════════════════════════════
   Animacje wejścia — okna addonów i przełączanie tabów
   ══════════════════════════════════════════════════════════════════════ */

@keyframes bm-win-enter {
  from { opacity: 0; transform: translateY(8px) scale(0.98); }
  to   { opacity: 1; transform: none; }
}

@keyframes bm-tab-enter {
  from { opacity: 0; transform: translateY(5px); }
  to   { opacity: 1; transform: none; }
}

.bm-addon-window.bm-win-is-new {
  animation: bm-win-enter 0.16s ease;
}

/* ══════════════════════════════════════════════════════════════════════
   Collapse / Pin — sterowanie oknem addonu
   ══════════════════════════════════════════════════════════════════════ */

.bm-win-ctrl-btn {
  width: 22px;
  height: 22px;
  font-size: 10px;
  opacity: 0.55;
  flex-shrink: 0;
  transition: opacity 0.15s, background 0.15s;
}

.bm-win-ctrl-btn:hover { opacity: 1; }
.bm-win-ctrl-btn.is-active { opacity: 1; color: var(--bm-warning); }

.bm-addon-win-header-ident { flex: 1 1 auto; min-width: 0; }

.bm-addon-window.is-collapsed .bm-addon-window-body,
.bm-addon-window.is-collapsed .bm-addon-win-content {
  display: none !important;
}

.bm-addon-window.is-collapsed {
  height: auto !important;
  max-height: none !important;
  min-height: 0 !important;
  resize: none;
}

.bm-addon-window.is-pinned .bm-addon-win-header,
.bm-addon-window.is-pinned .bm-addon-window-header {
  cursor: default;
}

.bm-addon-window.is-pinned::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 4px;
  pointer-events: none;
  box-shadow: inset 0 0 0 1px rgba(251, 191, 36, 0.25);
}

/* ══════════════════════════════════════════════════════════════════════
   Motywy UI BetterMargo — Red, Purple, Green, Blue
   ══════════════════════════════════════════════════════════════════════ */

/* ── Red ─────────────────────────────────────────────────────────── */
.bm-ui-theme-red {
  --bm-brand:     #f87171;
  --bm-brand-dim: rgba(248, 113, 113, 0.20);
  --bm-glass-bg:  rgba(18, 8, 8, 0.78);
  --bm-border-gold: rgba(248, 113, 113, 0.20);
}

.bm-ui-theme-red .bm-cw {
  border-color: rgba(248, 113, 113, 0.20);
  background:
