/* ════════════════════════════════════════════════════════════
   BetterMargo — Design System Tokens
   ════════════════════════════════════════════════════════════ */

:root {
  /* ── Backgrounds ─────────────────────── */
  --bm-bg-base:    rgba(10, 8, 16, 0.92);
  --bm-bg-surface: rgba(255, 255, 255, 0.02);
  --bm-bg-raised:  rgba(255, 255, 255, 0.04);

  /* ── Borders ─────────────────────────── */
  --bm-border-subtle:  rgba(255, 255, 255, 0.06);
  --bm-border-default: rgba(255, 255, 255, 0.10);
  --bm-border-strong:  rgba(255, 255, 255, 0.18);
  --bm-border-gold:    rgba(203, 172, 98, 0.22);

  /* ── Text ────────────────────────────── */
  --bm-text-primary:   rgba(255, 255, 255, 0.92);
  --bm-text-secondary: rgba(255, 255, 255, 0.60);
  --bm-text-tertiary:  rgba(255, 255, 255, 0.38);
  --bm-text-disabled:  rgba(255, 255, 255, 0.25);

  /* ── Brand ───────────────────────────── */
  --bm-brand:     #d9bc7a;
  --bm-brand-dim: rgba(217, 188, 122, 0.22);

  /* ── Semantic ────────────────────────── */
  --bm-success:    #4ade80;
  --bm-success-bg: rgba(74, 222, 128, 0.12);
  --bm-warning:    #fbbf24;
  --bm-warning-bg: rgba(251, 191, 36, 0.12);
  --bm-danger:     #f87171;
  --bm-danger-bg:  rgba(248, 113, 113, 0.12);
  --bm-info:       #60a5fa;
  --bm-info-bg:    rgba(96, 165, 250, 0.12);

  /* ── Radius ──────────────────────────── */
  --bm-r-sm:   6px;
  --bm-r-md:   8px;
  --bm-r-lg:   12px;
  --bm-r-pill: 999px;

  /* ── Glass ───────────────────────────── */
  --bm-glass-blur: blur(24px) saturate(1.6);
  --bm-glass-bg:   rgba(10, 8, 18, 0.74);

  /* ── Shadows ─────────────────────────── */
  --bm-shadow-window: 0 24px 64px rgba(0, 0, 0, 0.60), inset 0 1px 0 rgba(255, 255, 255, 0.05);
  --bm-shadow-float:  0 8px 32px rgba(0, 0, 0, 0.45);
}

/* ─────────────────────────────────────────────────────────── */

/* #bettermargo-launcher usunięty z DOM (JS) — kółkowaty launcher retired, wejście
   tylko przez natywny przycisk paska gry (#bm-native-btn). */

#bettermargo-root {
  position: fixed;
  right: 18px;
  bottom: 92px;
  z-index: 999999;
  font-family: "Cormorant Garamond", "Palatino Linotype", "Book Antiqua", Palatino, Georgia, serif;
  color: #ede0ca;
  /* wrapper przezroczysty dla kliknięć — łapie tylko widoczny panel (mount ma rozmiar panelu) */
  pointer-events: none;
}

#bettermargo-addon-layer {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 999998;
}

#bettermargo-addon-layer.bm-is-dragging {
  user-select: none;
}

#bettermargo-root.bm-is-dragging {
  user-select: none;
}

.bm-root {
  position: relative;
}

.bm-shell {
  display: flex;
  align-items: flex-end;
  justify-content: flex-end;
}

.bm-card,
/* Główny panel — ta sama ramka overlay co okna dodatków (reaguje na motyw) */
.bm-panel {
  border: none;
  border-radius: 4px;
  background: var(--bm-glass-bg);
  backdrop-filter: var(--bm-glass-blur);
  -webkit-backdrop-filter: var(--bm-glass-blur);
  box-shadow:
    0 0 0 1px #010101,
    0 0 0 2px var(--bm-brand),
    0 0 0 3px #0c0d0d,
    2px 2px 3px 3px rgba(12, 13, 13, 0.40);
}

.bm-card {
  width: 336px;
  padding: 8px;
  pointer-events: auto;
}

.bm-tone-boot {
  border-color: var(--bm-border-default);
}

.bm-tone-error {
  border-color: var(--bm-warning);
  box-shadow:
    var(--bm-shadow-window),
    inset 0 0 0 1px rgba(251, 191, 36, 0.18);
}

.bm-tone-denied {
  border-color: var(--bm-danger);
  box-shadow:
    var(--bm-shadow-window),
    inset 0 0 0 1px rgba(248, 113, 113, 0.18);
}

.bm-eyebrow,
.bm-panel-eyebrow {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.38);
}

.bm-title,
.bm-panel-title {
  margin: 4px 0 2px;
  font-size: 10px;
  font-weight: 700;
  line-height: 1.2;
  color: rgba(255, 255, 255, 0.9);
}

.bm-panel-subtitle {
  font-size: 10px;
  color: rgba(255, 255, 255, 0.46);
  line-height: 1.35;
}

.bm-addon-inline-note {
  display: flex;
  align-items: center;
  min-height: 32px;
  font-size: 10px;
  line-height: 1.35;
  color: rgba(255, 255, 255, 0.45);
}

.bm-copy,
.bm-text {
  margin: 0;
  font-size: 10px;
  line-height: 1.45;
  color: rgba(255, 255, 255, 0.58);
}

.bm-meta {
  margin-top: 6px;
  display: grid;
  gap: 6px;
}

.bm-meta-row {
  padding: 6px 10px;
  border-radius: 6px;
  background: rgba(255, 244, 215, 0.035);
  font-size: 10px;
  line-height: 1.45;
  color: #c6b59d;
}

/* ── Activation form ────────────────────────────── */

.bm-activation-section {
  margin-top: 6px;
  padding-top: 10px;
  border-top: 1px solid rgba(221, 192, 135, 0.1);
}

.bm-activation-title {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #d9bc7a;
  margin-bottom: 4px;
}

.bm-activation-desc {
  font-size: 10px;
  line-height: 1.4;
  color: #9e8e78;
  margin-bottom: 4px;
}

.bm-activation-form {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.bm-activation-input {
  width: 100%;
  padding: 6px 10px;
  border: 1px solid rgba(221, 192, 135, 0.15);
  border-radius: 6px;
  background: rgba(22, 20, 15, 0.6);
  color: #fff4d3;
  font-size: 10px;
  font-family: inherit;
  outline: none;
  transition: border-color 0.2s;
  box-sizing: border-box;
}

.bm-activation-input:focus {
  border-color: #d9bc7a;
}

.bm-activation-input::placeholder {
  color: #6b5e4e;
}

.bm-activation-input:disabled {
  opacity: 0.5;
}

.bm-activation-submit {
  width: 100%;
  padding: 5px 10px;
  border: 1px solid rgba(221, 192, 135, 0.2);
  border-radius: 6px;
  background: rgba(255, 241, 206, 0.06);
  color: #d9bc7a;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  font-family: inherit;
  cursor: pointer;
  transition: all 0.3s;
}

.bm-activation-submit:hover:not(:disabled) {
  background: rgba(255, 241, 206, 0.12);
}

.bm-activation-submit:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.bm-activation-error {
  margin-top: 4px;
  padding: 4px 8px;
  border-radius: var(--bm-r-md);
  background: var(--bm-danger-bg);
  color: var(--bm-danger);
  font-size: 10px;
  line-height: 1.4;
}

.bm-activation-success {
  margin-top: 4px;
  padding: 4px 8px;
  border-radius: var(--bm-r-md);
  background: var(--bm-success-bg);
  color: var(--bm-success);
  font-size: 10px;
  line-height: 1.4;
}

.bm-launcher {
  position: relative;
  width: 60px;
  height: 60px;
  border: none;
  border-radius: 50%;
  background: url('/static/logo.png') center / contain no-repeat;
  backdrop-filter: none;
  box-shadow: none;
  cursor: inherit;
  overflow: visible;
  touch-action: none;
  transition: opacity 0.2s ease, transform 0.2s ease;
}

.bm-launcher:hover {
  opacity: 0.88;
  transform: scale(1.04);
}

.bm-launcher.is-open {
  opacity: 1;
}

.bm-launcher-shine,
.bm-launcher-core,
.bm-launcher-ring {
  display: none;
}

.bm-launcher-status {
  display: none;
}

.bm-panel {
  position: relative;
  pointer-events: auto;
  width: min(96vw, 580px);
  height: min(88vh, 580px);
  padding: 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transform-origin: bottom right;
  transition:
    opacity 0.18s ease,
    transform 0.18s ease,
    visibility 0.18s ease;
}

.bm-panel.is-closed {
  opacity: 0;
  transform: translateY(14px) scale(0.97);
  visibility: hidden;
  pointer-events: none;
}

.bm-panel.is-open {
  opacity: 1;
  transform: translateY(0) scale(1);
  visibility: visible;
}

.bm-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  padding: 9px 12px 8px;
  border-bottom: 1px solid var(--bm-brand-dim);
  flex-shrink: 0;
  cursor: grab;
}

.bm-is-dragging .bm-panel-header {
  cursor: grabbing;
}

.bm-panel-brand {
  display: flex;
  align-items: baseline;
  gap: 6px;
}

.bm-panel-brand-name {
  font-size: 12px;
  font-weight: 800;
  letter-spacing: 0.02em;
  color: rgba(255, 255, 255, 0.88);
}

.bm-panel-brand-ver {
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.08em;
  color: rgba(255, 255, 255, 0.3);
}

.bm-panel-header-right {
  display: flex;
  align-items: center;
  gap: 8px;
}

.bm-panel-status-label {
  font-size: 9px;
  color: rgba(255, 255, 255, 0.32);
  max-width: 180px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bm-is-dragging .bm-panel-header {
  cursor: grabbing;
}

.bm-icon-button,
.bm-ghost-button,
.bm-primary-button,
.bm-tab,
.bm-install-button,
.bm-qf-slot {
  cursor: pointer;
  font-family: inherit;
  appearance: none;
  -webkit-appearance: none;
  box-sizing: border-box;
}

.bm-icon-button {
  width: 28px;
  height: 28px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 6px;
  background: rgba(255, 255, 255, 0.03);
  color: rgba(255, 255, 255, 0.65);
  font-size: 10px;
}

.bm-icon-button:hover,
.bm-ghost-button:hover,
.bm-tab:hover {
  background: rgba(255, 255, 255, 0.07);
}

.bm-panel-toolbar {
  display: none;
}

.bm-ghost-button,
.bm-primary-button {
  padding: 5px 10px;
  border-radius: 6px;
  border: 1px solid rgba(221, 192, 135, 0.08);
  background: rgba(255, 241, 206, 0.04);
  color: #c6b59d;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.03em;
  line-height: 1.2;
  transition: all 0.3s;
}

.bm-primary-button {
  border-color: rgba(221, 192, 135, 0.25);
  background: rgba(255, 241, 206, 0.07);
  color: #f0dfc0;
}

.bm-ghost-button:disabled,
.bm-primary-button:disabled,
.bm-icon-button:disabled,
.bm-tab:disabled {
  opacity: 0.45;
  cursor: not-allowed;
}

.bm-tabs {
  display: flex;
  gap: 2px;
  padding: 5px 8px 0;
  border-bottom: 1px solid var(--bm-brand-dim);
  flex-shrink: 0;
}

.bm-tabs .bm-tab.is-active {
  background: var(--bm-brand-dim);
  color: var(--bm-brand);
}

.bm-tab {
  flex: 1;
  padding: 6px 4px;
  border: none;
  border-radius: 5px 5px 0 0;
  background: transparent;
  color: rgba(255, 255, 255, 0.35);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.04em;
  transition: background 0.15s, color 0.15s;
}

.bm-tab.is-active {
  background: rgba(255, 255, 255, 0.07);
  color: rgba(255, 255, 255, 0.9);
}

.bm-panel-body {
  margin-top: 0;
  flex: 1 1 auto;
  min-height: 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  position: relative;
}

.bm-panel-body::-webkit-scrollbar {
  width: 5px;
}

.bm-panel-body::-webkit-scrollbar-track {
  background: transparent;
}

.bm-panel-body::-webkit-scrollbar-thumb {
  border-radius: 6px;
  background: rgba(255, 255, 255, 0.12);
}

.bm-install-button {
  padding: 6px 10px;
  border: 1px solid rgba(74, 222, 128, 0.2);
  border-radius: var(--bm-r-sm);
  background: var(--bm-success-bg);
  color: var(--bm-success);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.04em;
  cursor: pointer;
  font-family: inherit;
  transition: all 0.3s;
}

.bm-install-button.is-installed {
  border-color: var(--bm-border-subtle);
  background: var(--bm-bg-surface);
  color: var(--bm-text-tertiary);
}

.bm-grid {
  display: grid;
  gap: 6px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.bm-surface,
.bm-module-card {
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 8px;
  background: rgba(255, 255, 255, 0.02);
  padding: 8px;
}

.bm-surface-wide {
  grid-column: 1 / -1;
}

.bm-surface-title {
  margin-bottom: 4px;
  font-size: 10px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.38);
}

.bm-kv {
  display: grid;
  gap: 4px;
}

.bm-kv-row {
  display: flex;
  justify-content: space-between;
  gap: 6px;
  font-size: 10px;
  color: rgba(255, 255, 255, 0.55);
}

.bm-kv-row strong {
  color: rgba(255, 255, 255, 0.88);
  text-align: right;
}

.bm-inline-actions {
  margin-top: 6px;
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.bm-module-list {
  display: grid;
  gap: 6px;
}

.bm-addon-list {
  display: grid;
  gap: 6px;
}

.bm-addon-card {
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 8px;
  background: rgba(255, 255, 255, 0.02);
  padding: 6px 8px;
  display: grid;
  gap: 6px;
}

.bm-addon-view {
  display: grid;
  gap: 6px;
}

.bm-addon-view-head {
  margin-top: 0;
  justify-content: space-between;
  align-items: center;
  position: relative;
  padding-bottom: 0;
  background: transparent;
}

.bm-addon-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 6px;
  padding: 2px 0;
}

.bm-addon-ident {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 6px;
}

.bm-addon-ident-copy {
  min-width: 0;
}

.bm-addon-icon-box {
  --bm-addon-icon: none;
  color: #d7cfba;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 1px solid rgba(126, 112, 86, 0.55);
  border-radius: 6px;
  background: rgba(18, 18, 18, 0.78);
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.03),
    0 0 0 1px rgba(6, 6, 6, 0.7);
}

.bm-addon-icon-box.is-card {
  width: 34px;
  height: 34px;
}

.bm-addon-icon-box.is-window {
  width: 28px;
  height: 28px;
  border-radius: 8px;
}

.bm-addon-icon-box.is-dock {
  width: 22px;
  height: 22px;
  border: 0;
  background: transparent;
  box-shadow: none;
}

.bm-addon-icon-glyph {
  width: 18px;
  height: 18px;
  display: block;
  background-color: currentColor;
  -webkit-mask-image: var(--bm-addon-icon);
  mask-image: var(--bm-addon-icon);
  -webkit-mask-position: center;
  mask-position: center;
  -webkit-mask-repeat: no-repeat;
  mask-repeat: no-repeat;
  -webkit-mask-size: contain;
  mask-size: contain;
}

.bm-addon-icon-box.is-window .bm-addon-icon-glyph {
  width: 16px;
  height: 16px;
}

.bm-addon-icon-box.is-dock .bm-addon-icon-glyph {
  width: 20px;
  height: 20px;
}

.bm-addon-subtitle {
  margin-top: 2px;
  font-size: 9px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #b29979;
}

.bm-upgrade-view {
  gap: 6px;
}

.bm-autoheal-view {
  gap: 6px;
}

.bm-qf-shell {
  border: 1px solid rgba(221, 192, 135, 0.08);
  border-radius: 8px;
  background:
    linear-gradient(180deg, rgba(255, 243, 217, 0.03), rgba(255, 243, 217, 0.01)),
    rgba(255, 255, 255, 0.012);
  padding: 6px 8px;
  display: grid;
  gap: 6px;
}

.bm-addon-dock {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6px;
  pointer-events: none;
}

.bm-addon-dock-row {
  display: flex;
  gap: 4px;
  padding: 6px;
  border-radius: 6px;
  background: rgba(0, 0, 0, 0.24);
  pointer-events: auto;
  cursor: grab;
  user-select: none;
}

.bm-addon-dock-row:active {
  cursor: grabbing;
}

.bm-addon-dock.in-interface {
  top: 14px;
  right: 18px;
}

.bm-addon-dock.is-fallback {
  top: 14px;
  right: 18px;
  bottom: auto;
}

.bm-addon-dock-button {
  width: 32px;
  height: 32px;
  border: 1px solid rgba(129, 114, 86, 0.58);
  border-radius: 8px;
  background: rgba(0, 0, 0, 0.72);
  color: #d6cfba;
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.03),
    0 0 0 1px rgba(6, 6, 6, 0.7);
  pointer-events: auto;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  transition: background 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
  cursor: grab;
}

.bm-addon-dock-button:hover {
  background: rgba(32, 32, 32, 0.78);
}

.bm-addon-dock-button:active,
.bm-addon-dock-button.is-dragging {
  cursor: grabbing;
  opacity: 0.72;
}

.bm-addon-dock-button.is-open {
  border-color: rgba(77, 144, 98, 0.72);
  background: rgba(50, 88, 54, 0.82);
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.04),
    0 0 0 1px rgba(6, 6, 6, 0.7);
}

.bm-addon-dock-button-label {
  display: none;
}

.bm-upgrade-counter-popup {
  min-width: 96px;
  padding: 6px 8px;
  border: 1px solid rgba(217, 187, 129, 0.18);
  border-radius: 8px;
  background:
    radial-gradient(circle at top left, rgba(255, 214, 132, 0.16), transparent 42%),
    linear-gradient(180deg, rgba(31, 21, 15, 0.96), rgba(15, 20, 32, 0.96));
  box-shadow:
    0 14px 34px rgba(0, 0, 0, 0.34),
    inset 0 1px 0 rgba(255, 255, 255, 0.06);
  color: #fff6d5;
  pointer-events: none;
}

.bm-upgrade-counter-popup.is-loading {
  opacity: 0.82;
}

.bm-upgrade-counter-label {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.11em;
  text-transform: uppercase;
  color: #c8af7a;
}

.bm-upgrade-counter-value {
  margin-top: 4px;
  font-size: 18px;
  font-weight: 800;
  line-height: 1;
  letter-spacing: 0.02em;
  color: #fff3c4;
}

.bm-qf-counter-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2px;
  padding: 3px 6px;
  min-width: 44px;
  border: 1px solid var(--bm-border-gold, rgba(217, 187, 129, 0.22));
  border-radius: 6px;
  background: var(--bm-brand-dim, rgba(255, 214, 132, 0.06));
  color: var(--bm-brand, #e8d49a);
  cursor: pointer;
  transition: background 0.15s, border-color 0.15s;
  line-height: 1;
}

.bm-qf-counter-btn:hover {
  background: var(--bm-brand-dim, rgba(255, 214, 132, 0.12));
  border-color: var(--bm-border-gold, rgba(217, 187, 129, 0.42));
}

.bm-qf-counter-btn.is-open {
  background: var(--bm-brand-dim, rgba(255, 214, 132, 0.14));
  border-color: var(--bm-brand, rgba(255, 200, 80, 0.5));
  box-shadow: 0 0 0 1px var(--bm-brand-dim, rgba(255, 200, 80, 0.15));
}

.bm-qf-counter-btn.is-loading {
  opacity: 0.7;
}

.bm-qf-counter-icon {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 4px;
  overflow: hidden;
}

.bm-qf-counter-img {
  width: 28px;
  height: 28px;
  object-fit: contain;
  image-rendering: pixelated;
}

.bm-qf-counter-typeicon {
  font-size: 15px;
  line-height: 1;
  color: #c8af7a;
}

.bm-qf-counter-val {
  font-size: 10px;
  font-weight: 700;
  color: #e8d49a;
  white-space: nowrap;
  letter-spacing: 0.02em;
}

.bm-qf-counter-sep {
  color: rgba(200, 175, 122, 0.55);
  font-weight: 400;
}

.bm-qf-counter-slot-row {
  display: flex;
  gap: 4px;
  flex-wrap: wrap;
  margin-top: 4px;
}

.bm-chip-button {
  padding: 3px 8px;
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: 4px;
  background: rgba(255, 255, 255, 0.04);
  color: #b0b0b0;
  font-size: 11px;
  cursor: pointer;
  transition: background 0.12s, border-color 0.12s, color 0.12s;
  line-height: 1.4;
}

.bm-chip-button:hover {
  background: rgba(255, 255, 255, 0.08);
  color: #e0e0e0;
}

.bm-chip-button.is-active {
  border-color: rgba(255, 200, 80, 0.55);
  background: rgba(255, 200, 80, 0.1);
  color: #f5d97a;
}

/* ── Counter Widget mini floating window ─────────────────── */
.bm-cw {
  position: fixed;
  z-index: 99990;
  min-width: 100px;
  border: 1px solid var(--bm-border-gold, rgba(217, 187, 129, 0.22));
  border-radius: 8px;
  background:
    radial-gradient(circle at top left, var(--bm-brand-dim, rgba(255, 214, 132, 0.1)), transparent 55%),
    var(--bm-glass-bg, linear-gradient(180deg, rgba(28, 22, 14, 0.97) 0%, rgba(14, 18, 28, 0.97) 100%));
  box-shadow:
    0 16px 40px rgba(0, 0, 0, 0.5),
    inset 0 1px 0 rgba(255, 255, 255, 0.06);
  color: var(--bm-brand, #e8d49a);
  pointer-events: auto;
  user-select: none;
  cursor: grab;
}

.bm-cw:active {
  cursor: grabbing;
}

.bm-cw.is-loading {
  opacity: 0.75;
}


.bm-cw-body {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 10px;
}

.bm-cw-icon-wrap {
  width: 36px;
  height: 36px;
  flex-shrink: 0;
  border-radius: 5px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  background: rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.bm-cw-item-img {
  width: 36px;
  height: 36px;
  object-fit: contain;
  image-rendering: pixelated;
}

.bm-cw-item-ph {
  font-size: 18px;
  color: #c8af7a;
  line-height: 1;
}

.bm-cw-count {
  font-size: 16px;
  font-weight: 800;
  line-height: 1;
  letter-spacing: 0.02em;
  color: var(--bm-brand, #fff3c4);
  white-space: nowrap;
}

.bm-cw-sep {
  font-size: 13px;
  font-weight: 400;
  color: var(--bm-border-gold, rgba(200, 175, 122, 0.45));
  margin: 0 1px;
}


/* Wspólna ramka "overlay" wszystkich okien dodatków — kolor obwódki i tła
   podąża za --bm-brand / --bm-glass-bg ustawianymi przez wybrany motyw UI. */
.bm-addon-window {
  position: fixed;
  width: min(84vw, 720px);
  max-height: min(90vh, 820px);
  border: none;
  border-radius: 4px;
  background: var(--bm-glass-bg);
  box-shadow:
    0 0 0 1px #010101,
    0 0 0 2px var(--bm-brand),
    0 0 0 3px #0c0d0d,
    2px 2px 3px 3px rgba(12, 13, 13, 0.40);
  pointer-events: auto;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.bm-addon-window-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 6px;
  padding: 6px 8px 8px;
  border-bottom: 1px solid var(--bm-brand-dim);
  cursor: grab;
}

.bm-addon-window-heading {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 6px;
}

#bettermargo-addon-layer.bm-is-dragging .bm-addon-window-header {
  cursor: grabbing;
}

.bm-addon-window-title {
  margin-top: 2px;
  font-size: 14px;
  line-height: 1.15;
  color: #fff4d3;
}

.bm-addon-window-body {
  flex: 1;
  min-height: 0;
  overflow-x: hidden;
  overflow-y: auto;
  overscroll-behavior: contain;
  scrollbar-gutter: stable both-edges;
  scrollbar-width: thin;
  scrollbar-color: rgba(215, 186, 122, 0.28) transparent;
  padding: 6px 4px 8px 10px;
}

.bm-addon-window-body::-webkit-scrollbar,
.bm-qf-ingredients::-webkit-scrollbar {
  width: 10px;
}

.bm-addon-window-body::-webkit-scrollbar-track,
.bm-qf-ingredients::-webkit-scrollbar-track {
  background: transparent;
}

.bm-addon-window-body::-webkit-scrollbar-thumb,
.bm-qf-ingredients::-webkit-scrollbar-thumb {
  border-radius: 999px;
  background: rgba(215, 186, 122, 0.22);
}

.bm-qf-shell-locked {
  gap: 6px;
}.bm-autoheal-hero-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 6px;
}.bm-autoheal-summary-grid,
.bm-autoheal-stock-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 4px;
}.bm-autoheal-threshold .bm-number-input {
  text-align: center;
  font-weight: 700;
}.bm-autoheal-card .bm-setting {
  min-height: 28px;
  padding: 4px 6px;
  border: 1px solid rgba(214, 186, 129, 0.08);
  border-radius: 6px;
  background: rgba(255, 244, 219, 0.022);
  align-items: center;
}.bm-qf-limit {
  text-align: center;
  font-size: 10px;
  font-weight: 700;
  color: #f3deb0;
  padding: 6px 8px;
  border-radius: 6px;
  background: linear-gradient(135deg, rgba(120, 86, 34, 0.28), rgba(32, 45, 68, 0.34));
}

.bm-qf-slots-line {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 4px;
}

.bm-qf-slot {
  min-width: 0;
  min-height: 68px;
  width: 100%;
  padding: 6px;
  border: 1px solid rgba(217, 187, 129, 0.09);
  border-radius: 8px;
  background: rgba(255, 244, 219, 0.03);
  outline: none;
  box-shadow: none;
  color: #f0e4c7;
  text-align: left;
  cursor: pointer;
  font-family: inherit;
}

.bm-qf-slot:hover {
  background: rgba(255, 250, 236, 0.05);
}

.bm-qf-slot.is-active {
  border-color: rgba(225, 192, 126, 0.22);
  box-shadow: inset 0 0 0 1px rgba(83, 132, 194, 0.16);
}

.bm-qf-slot-type {
  display: block;
  font-size: 9px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #cdb289;
}

.bm-qf-slot-name {
  display: block;
  margin-top: 2px;
  min-height: 26px;
  font-size: 10px;
  line-height: 1.3;
  color: #fff2ca;
}

.bm-qf-slot-progress {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 3px;
  padding: 1px 5px;
  border-radius: 999px;
  background: rgba(49, 92, 145, 0.24);
  color: #d7ebff;
  font-size: 9px;
  letter-spacing: 0.04em;
}

.bm-qf-slot > span {
  pointer-events: none;
}

.bm-qf-active-meta,

.bm-qf-active-meta strong,

.bm-qf-check-grid {
  display: grid;
  gap: 2px 8px;
  grid-template-columns: 1fr 1fr;
}

.bm-qf-check-grid-ignore {
  grid-template-columns: repeat(6, minmax(0, 1fr));
}

.bm-qf-ingredients {
  max-height: min(34vh, 280px);
  overflow-x: hidden;
  overflow-y: auto;
  overscroll-behavior: contain;
  padding-right: 4px;
}

.bm-qf-lock-copy {
  padding: 5px 8px;
  border-radius: 8px;
  background: rgba(255, 240, 208, 0.04);
  color: #d7c6ab;
  font-size: 10px;
  line-height: 1.35;
}

.bm-qf-hero {
  display: grid;
  gap: 6px;
  padding: 8px;
  border: 1px solid rgba(214, 186, 129, 0.08);
  border-radius: 8px;
  background:
    radial-gradient(circle at top left, rgba(215, 183, 121, 0.12), transparent 34%),
    linear-gradient(180deg, rgba(255, 245, 223, 0.04), rgba(255, 245, 223, 0.014)),
    rgba(255, 255, 255, 0.014);
  min-width: 0;
}

.bm-qf-top-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.08fr) minmax(220px, 0.92fr);
  gap: 6px;
  align-items: start;
}

.bm-qf-slots-panel {
  display: grid;
  align-content: start;
  min-width: 0;
}

.bm-qf-panel,
.bm-qf-selected-card {
  display: grid;
  gap: 6px;
  min-width: 0;
}

.bm-qf-hero-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 6px;
}

.bm-qf-hero-header > div:first-child {
  min-width: 0;
}

.bm-qf-hero-footer {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 92px;
  gap: 6px;
  align-items: center;
}

.bm-qf-selected-card,
.bm-qf-panel {
  padding: 6px 8px;
  border: 1px solid rgba(214, 186, 129, 0.08);
  border-radius: 8px;
  background:
    linear-gradient(180deg, rgba(255, 248, 231, 0.03), rgba(255, 248, 231, 0.012)),
    rgba(255, 255, 255, 0.012);
}

.bm-qf-panel-label {
  font-size: 9px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #d9bc7a;
}

.bm-qf-selected-box {
  display: flex;
  align-items: center;
  gap: 6px;
  min-height: 42px;
}

.bm-qf-selected-icon-wrap,
.bm-qf-selected-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  flex: 0 0 auto;
  overflow: hidden;
  border: 1px solid rgba(214, 186, 129, 0.12);
  border-radius: 8px;
  background:
    radial-gradient(circle at 35% 35%, rgba(255, 220, 140, 0.18), transparent 40%),
    linear-gradient(180deg, rgba(35, 28, 22, 0.98), rgba(16, 20, 28, 0.98));
}

.bm-qf-selected-icon {
  width: 32px;
  height: 32px;
  object-fit: contain;
  image-rendering: auto;
}

.bm-qf-selected-placeholder {
  font-size: 13px;
  font-weight: 800;
  color: #ffe6b2;
}

.bm-qf-selected-copy {
  min-width: 0;
}

.bm-qf-selected-name {
  font-size: 10px;
  font-weight: 700;
  line-height: 1.25;
  color: #fff2ca;
  word-break: break-word;
}

.bm-qf-hero-buttons {
  display: grid;
  grid-template-columns: minmax(0, 108px) 76px;
  gap: 6px;
  justify-content: start;
}

.bm-qf-hero-buttons > * {
  width: 100%;
  min-width: 0;
}

.bm-qf-hero-buttons .bm-primary-button,
.bm-qf-hero-buttons .bm-ghost-button {
  min-height: 28px;
  padding: 4px 8px;
  font-size: 10px;
}

.bm-qf-run-button {
  min-height: 28px;
  min-width: 108px;
  font-size: 10px;
  font-weight: 800;
}

.bm-qf-hotkey-chip {
  padding: 5px 8px;
  border: 1px solid rgba(214, 186, 129, 0.08);
  border-radius: 8px;
  background: rgba(255, 244, 219, 0.026);
  min-width: 0;
  text-align: center;
  font-size: 10px;
  color: #cfbda1;
}

.bm-qf-hotkey-chip strong {
  color: #fff2ca;
}

.bm-qf-slot-rail {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

/* ── Upgrade V2 — visual slots (MargoPlus-style) ──────────────── */
.bm-qf-shell-v2 {
  display: flex;
  flex-direction: column;
  gap: 5px;
}

.bm-qf-v2-slots {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 4px;
}

.bm-qf-sv {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  cursor: pointer;
  border: 1px solid rgba(217, 187, 129, 0.12);
  border-radius: 6px;
  background: rgba(255, 244, 219, 0.03);
  padding: 4px 3px 3px;
  gap: 2px;
  transition: border-color 0.15s, background 0.15s, box-shadow 0.15s;
  user-select: none;
}

.bm-qf-sv:hover {
  border-color: rgba(217, 187, 129, 0.24);
  background: rgba(255, 244, 219, 0.058);
}

.bm-qf-sv.is-active {
  border-color: rgba(225, 192, 126, 0.32);
  box-shadow: 0 0 0 1px rgba(83, 132, 194, 0.14), inset 0 0 8px rgba(215, 183, 121, 0.06);
}

.bm-qf-sv.ui-droppable-hover {
  border-color: rgba(134, 198, 255, 0.55) !important;
  background: rgba(83, 132, 194, 0.13) !important;
  box-shadow: 0 0 0 2px rgba(83, 132, 194, 0.24) !important;
}

.bm-qf-sv-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
  border-radius: 5px;
  background: rgba(255, 244, 219, 0.04);
  overflow: hidden;
  flex-shrink: 0;
}

.bm-qf-sv-img {
  width: 28px;
  height: 28px;
  object-fit: contain;
  image-rendering: pixelated;
}

.bm-qf-sv-typeicon {
  font-size: 14px;
  line-height: 1;
  color: rgba(215, 183, 121, 0.38);
  pointer-events: none;
}

.bm-qf-sv.is-assigned .bm-qf-sv-icon {
  background: rgba(255, 244, 219, 0.07);
}

.bm-qf-sv-progress {
  position: relative;
  width: 100%;
  height: 3px;
  background: rgba(255, 255, 255, 0.07);
  border-radius: 999px;
  overflow: visible;
}

.bm-qf-sv-bar {
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  background: linear-gradient(90deg, rgba(83, 132, 194, 0.65), rgba(83, 178, 255, 0.85));
  border-radius: 999px;
  transition: width 0.4s ease;
  min-width: 0;
}

.bm-qf-sv-pct {
  position: absolute;
  top: 4px;
  right: 0;
  font-size: 8px;
  color: #a9bfdc;
  pointer-events: none;
  white-space: nowrap;
}

.bm-qf-sv-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  gap: 2px;
  min-height: 16px;
}

.bm-qf-sv-label {
  font-size: 9px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #cdb289;
  pointer-events: none;
  flex: 1;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.bm-qf-sv-clear {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 14px;
  height: 14px;
  border: none;
  border-radius: 50%;
  background: rgba(255, 100, 80, 0.2);
  color: rgba(255, 150, 110, 0.85);
  font-size: 10px;
  line-height: 1;
  cursor: pointer;
  padding: 0;
  font-family: inherit;
  transition: background 0.15s;
  flex-shrink: 0;
}

.bm-qf-sv-clear:hover {
  background: rgba(255, 80, 60, 0.4);
  color: #ffbb99;
}

.bm-qf-v2-action-bar {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
}

.bm-qf-v2-action-bar .bm-primary-button {
  flex: 1;
  min-width: 60px;
}

.bm-qf-v2-status {
  margin: 0;
}

[data-bm-addon-window-handle] .bm-qf-sv {
  border-color: rgba(255, 255, 255, 0.07);
  background: rgba(255, 255, 255, 0.02);
}

[data-bm-addon-window-handle] .bm-qf-sv:hover {
  background: rgba(255, 255, 255, 0.04);
}

[data-bm-addon-window-handle] .bm-qf-sv.is-active {
  border-color: rgba(255, 255, 255, 0.18);
  box-shadow: inset 0 0 0 1px rgba(100, 160, 255, 0.14);
}

.bm-qf-slot {
  min-height: 76px;
  display: grid;
  gap: 4px;
}

.bm-qf-slot-top,
.bm-qf-slot-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 4px;
}

.bm-qf-slot-state,
.bm-qf-slot-action {
  font-size: 9px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #a9bfdc;
}

.bm-qf-slot-name {
  min-height: 26px;
  margin-top: 0;
}

.bm-qf-slot-footer {
  margin-top: auto;
}

.bm-qf-control-bar {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr);
  gap: 6px;
  align-items: center;
}

.bm-qf-settings-board {
  display: flex;
  flex-direction: column;
  gap: 6px;
  align-items: stretch;
}
.bm-qf-settings-board .bm-qf-panel {
  min-width: 0;
}

.bm-qf-panel-wide {
  grid-column: 1 / -1;
}

.bm-qf-filter-grid {
  display: grid;
  gap: 4px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.bm-qf-ignore-grid {
  display: grid;
  gap: 4px;
  grid-template-columns: repeat(4, minmax(0, 1fr));
}
.bm-qf-ignore-grid .bm-setting {
  min-width: 0;
}
.bm-qf-ignore-grid .bm-setting span {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.bm-qf-panel .bm-setting {
  display: flex;
  align-items: center;
  gap: 6px;
  min-height: 28px;
  padding: 4px 6px;
  border: 1px solid rgba(214, 186, 129, 0.08);
  border-radius: 6px;
  background: rgba(255, 244, 219, 0.022);
}

.bm-qf-panel .bm-setting input {
  margin-top: 0;
}

.bm-qf-panel .bm-range-block {
  margin-top: 0;
  padding: 6px 8px;
  border: 1px solid rgba(214, 186, 129, 0.08);
  border-radius: 8px;
  background: rgba(255, 244, 219, 0.022);
}


.bm-qf-keybind-box-inline {
  display: flex;
  flex-direction: column;
  gap: 2px;
  min-width: 80px;
  max-width: 120px;
  align-items: stretch;
  justify-self: start;
}

.bm-qf-keybind-box-inline .bm-keybind-input {
  width: 100%;
  min-width: 60px;
  max-width: 120px;
  height: 32px;
  box-sizing: border-box;
}

.bm-module-card-featured {
  padding: 8px;
}

.bm-module-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 6px;
  margin-bottom: 4px;
}

.bm-module-name {
  font-size: 10px;
  font-weight: 700;
  color: #fff2ca;
}

.bm-module-id {
  margin-top: 4px;
  font-size: 10px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #b29979;
}

.bm-badge {
  padding: 5px 8px;
  border-radius: 999px;
  font-size: 9px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.bm-badge.is-on {
  background: var(--bm-success-bg);
  color: var(--bm-success);
}

.bm-badge.is-off {
  background: var(--bm-warning-bg);
  color: var(--bm-warning);
}

.bm-module-toggle {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-top: 6px;
  padding: 6px 8px;
  border-radius: 8px;
  background: rgba(255, 241, 206, 0.04);
  color: #f0dfc0;
  font-size: 10px;
}

.bm-module-toggle-inline {
  margin-top: 0;
  padding: 6px 8px;
}

.bm-module-stats {
  margin-top: 6px;
  display: grid;
  gap: 6px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.bm-stat-chip {
  padding: 6px 8px;
  border-radius: 8px;
  background: rgba(255, 247, 228, 0.04);
  border: 1px solid rgba(214, 186, 129, 0.08);
}

.bm-stat-chip span {
  display: block;
  margin-bottom: 4px;
  font-size: 9px;
  letter-spacing: 0.09em;
  text-transform: uppercase;
  color: #ac9677;
}

.bm-stat-chip strong {
  color: #fff2ca;
  font-size: 10px;
}

.bm-kv-compact {
  margin-top: 6px;
}

.bm-setting {
  display: flex;
  align-items: flex-start;
  gap: 6px;
  padding: 5px 0;
  color: #dbcdb8;
  font-size: 10px;
  line-height: 1.35;
}

.bm-setting input {
  margin-top: 3px;
}

.bm-setting input[type="checkbox"] {
  accent-color: #b98233;
}

.bm-setting span,
.bm-range-block span,
.bm-range-block strong,
.bm-qf-keybind-box span {
  color: inherit;
}

.bm-helper-copy {
  margin-top: 4px;
  font-size: 10px;
  color: #b8a791;
}

.bm-setting-compact {
  padding: 6px 0;
}

.bm-keybind-input {
  width: 100%;
