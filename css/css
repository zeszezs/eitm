/* ══════════════════════════════════════════════════════════════════════
   FriendsOnline
   ══════════════════════════════════════════════════════════════════════ */
.bm-addon-window-friendsonline { width: min(82vw, 260px); }

.bm-cm-body {
  display: flex;
  flex-direction: column;
  height: 100%;
  min-height: 0;
  gap: 0;
}

.bm-cm-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 4px 8px 6px;
  flex-shrink: 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.bm-cm-title {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.40);
}

.bm-cm-title strong {
  color: var(--bm-brand);
}

.bm-cm-refresh {
  padding: 2px 6px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: var(--bm-r-sm);
  background: rgba(255, 255, 255, 0.03);
  color: rgba(255, 255, 255, 0.45);
  font-size: 12px;
  cursor: pointer;
  font-family: inherit;
  transition: color 0.15s, background 0.15s;
}

.bm-cm-refresh:hover { color: rgba(255, 255, 255, 0.85); background: rgba(255, 255, 255, 0.08); }
.bm-cm-refresh-busy { opacity: 0.4; pointer-events: none; }

.bm-cm-list {
  flex: 1 1 auto;
  min-height: 0;
  overflow-y: auto;
  overflow-x: hidden;
  padding: 4px 4px;
  display: flex;
  flex-direction: column;
  gap: 2px;
  scrollbar-width: thin;
  scrollbar-color: rgba(255, 255, 255, 0.1) transparent;
}

.bm-cm-member {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 5px 6px;
  border-radius: var(--bm-r-sm);
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid rgba(255, 255, 255, 0.04);
  transition: background 0.12s;
}

.bm-cm-member:hover { background: rgba(255, 255, 255, 0.05); }

.bm-cm-avatar {
  width: 28px;
  height: 28px;
  flex-shrink: 0;
  border-radius: 4px;
  background: rgba(255, 255, 255, 0.06) no-repeat center / contain;
  overflow: hidden;
}

.bm-cm-info {
  flex: 1 1 auto;
  min-width: 0;
}

.bm-cm-nick {
  font-size: 10px;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.85);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bm-cm-meta {
  font-size: 9px;
  color: rgba(255, 255, 255, 0.38);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bm-cm-actions { flex-shrink: 0; }

.bm-cm-action {
  width: 22px;
  height: 22px;
  border: 1px solid rgba(74, 222, 128, 0.25);
  border-radius: 4px;
  background: rgba(74, 222, 128, 0.08);
  color: var(--bm-success);
  font-size: 14px;
  line-height: 1;
  cursor: pointer;
  font-family: inherit;
  transition: background 0.12s;
}

.bm-cm-action:hover { background: rgba(74, 222, 128, 0.18); }

.bm-cm-empty {
  color: rgba(255, 255, 255, 0.25);
  font-size: 9px;
  text-align: center;
  padding: 12px 0;
}

/* ══════════════════════════════════════════════════════════════════════
   CharSwitcher — styl jak MargoPlus (icon grid z level badge)
   ══════════════════════════════════════════════════════════════════════ */
/* ══ CharSwitcher — zero chrome, same ikony + światy ══════════════════ */
.bm-addon-window-charswitcher {
  background: none !important; border: none !important;
  box-shadow: none !important; border-radius: 0 !important;
  width: auto !important; min-width: 0 !important; max-width: none !important;
  height: auto !important; max-height: none !important;
  overflow: visible !important;
}
.bm-addon-window-charswitcher .bm-addon-window-header,
.bm-addon-window-charswitcher .bm-addon-win-header { display: none !important; }
.bm-addon-window-charswitcher .bm-addon-window-body {
  padding: 0 !important; height: auto !important; max-height: none !important;
  overflow: visible !important; flex: none !important; background: none !important;
}

.bm-cs-bare {
  background: none; border: none;
  padding: 2px; display: inline-flex;
  flex-direction: column; gap: 3px; user-select: none;
}

.bm-cs-wtabs { display: flex; align-items: center; gap: 2px; justify-content: center; }
.bm-cs-wtab {
  padding: 1px 5px; font-size: 9px; font-weight: 700; font-family: inherit;
  background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.10);
  border-radius: 3px; color: rgba(255,255,255,0.40); cursor: pointer; transition: all 0.1s;
}
.bm-cs-wtab:hover { background: rgba(255,255,255,0.10); color: rgba(255,255,255,0.80); }
.bm-cs-wtab.is-active {
  background: rgba(217,188,122,0.14); border-color: rgba(217,188,122,0.30); color: var(--bm-brand);
}
.bm-cs-wpager {
  padding: 0 3px; font-size: 13px; line-height: 1; font-family: inherit;
  background: none; border: none; color: rgba(255,255,255,0.45);
  cursor: pointer; transition: color 0.1s;
}
.bm-cs-wpager:hover { color: rgba(255,255,255,0.9); }
.bm-cs-wpager-ph { display: inline-block; width: 14px; }

.bm-cs-icons { display: flex; flex-wrap: wrap; gap: 2px; justify-content: center; }
.bm-cs-icon-wrap {
  position: relative; background: none; border: none; padding: 0;
  cursor: pointer; transition: opacity 0.15s;
}
.bm-cs-icon-wrap:disabled { cursor: default; }
.bm-cs-icon-wrap:hover:not(:disabled) .bm-cs-icon-char { filter: brightness(1.3); }
.bm-cs-icon-wrap.is-current .bm-cs-icon-char { outline: 2px solid rgba(74,222,128,0.75); outline-offset: 1px; }
.bm-cs-icon-char {
  width: 32px; height: 32px; background-size: 128px 192px;
  background-repeat: no-repeat; background-position: 0 0;
  background-color: rgba(255,255,255,0.04); border-radius: 2px; display: block; transition: filter 0.15s;
}
.bm-cs-icon-level {
  position: absolute; bottom: -1px; left: 0; width: 32px; text-align: center;
  font-size: 9px; font-weight: 700; line-height: 11px; height: 11px;
  color: #ccc; background: rgba(0,0,0,0.72); border-radius: 2px;
  pointer-events: none; overflow: hidden;
}
.bm-cs-sline { font-size: 9px; text-align: center; padding: 1px 2px; border-radius: 2px; }
.bm-cs-sline.is-switching { color: var(--bm-info); }
.bm-cs-sline.is-error { color: var(--bm-danger); font-size: 8px; }
.bm-cs-sline.is-guest { color: rgba(251,191,36,0.65); }
.bm-cs-no-chars { font-size: 9px; color: rgba(255,255,255,0.25); padding: 4px 2px; }

/* ══════════════════════════════════════════════════════════════════════
   MailGrabber
   ══════════════════════════════════════════════════════════════════════ */
/* Button injected directly into game's mail window footer */
.bm-mg-grab-btn {
  display: inline-flex; align-items: center;
  padding: 3px 10px; margin: 2px 3px;
  background: rgba(74,222,128,0.12); border: 1px solid rgba(74,222,128,0.28);
  border-radius: 3px; color: #4ade80; font-size: 11px; font-weight: 700;
  cursor: pointer; font-family: inherit; transition: background 0.12s;
  text-shadow: 0 0 8px rgba(74,222,128,0.4);
}
.bm-mg-grab-btn:hover { background: rgba(74,222,128,0.22); }

/* ══════════════════════════════════════════════════════════════════════
   Dobijara — okno w stylu Margonem
   ══════════════════════════════════════════════════════════════════════ */

/* ── Wspólna ramka okna "kompaktowego" (bm-db-*) — reaguje na motyw UI ─── */
/* Wszystkie dodatki ze zwartym panelem (Dobijara, AttackOnTitan, ...) używają
   tej klasy zamiast osobnego .bm-addon-window-<id>. Kolor obwódki i tła
   podąża za --bm-brand / --bm-glass-bg ustawianymi przez wybrany motyw UI. */
.bm-db-shell {
  width: 248px;
  height: auto !important;
  max-height: none !important;
  border-radius: 2px;
}

/* Body okna — bez nadmiarowego paddingu, auto wysokość, własny scroll obsługuje widok */
.bm-db-shell .bm-addon-window-body {
  padding: 0 !important;
  scrollbar-width: none;
  flex: none !important;
  overflow: visible !important;
}
.bm-db-shell .bm-addon-window-body::-webkit-scrollbar {
  display: none;
}

/* Compact: body zawsze widoczny (stan zwinięcia obsługuje sam widok JS) */
.bm-db-shell.is-collapsed .bm-addon-window-body {
  display: block !important;
}

/* ── Zawartość okna ───────────────────────────────────────── */

/* Główny kontener treści */
.bm-db-win {
  display: flex;
  flex-direction: column;
  font-size: 11px;
  font-weight: bold;
  color: #fff;
  user-select: none;
}

/* Nagłówek kontrolny: przycisk Włącz/Wyłącz + status + ctrl btns */
.bm-db-header {
  display: flex;
  align-items: center;
  gap: 5px;
  padding: 5px 6px;
  background: rgba(255,255,255,0.03);
  cursor: grab;
}

/* Kontener przycisków collapse + close */
.bm-db-hdr-ctrl {
  display: flex;
  align-items: center;
  gap: 1px;
  flex-shrink: 0;
  margin-left: auto;
}

/* Przyciski collapse i close w pasku kontrolnym */
.bm-db-ctrl-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 18px;
  height: 18px;
  padding: 0;
  font-size: 11px;
  line-height: 1;
  font-family: inherit;
  cursor: pointer;
  border: none;
  background: transparent;
  color: rgba(255, 255, 255, 0.45);
  border-radius: 2px;
  transition: background 0.1s, color 0.1s;
}
.bm-db-ctrl-btn:hover {
  background: rgba(255, 255, 255, 0.10);
  color: rgba(255, 255, 255, 0.90);
}

/* Przycisk Włącz / Wyłącz — styl guzika Margonem */
.bm-db-power {
  flex-shrink: 0;
  padding: 2px 10px;
  font-size: 10px;
  font-family: inherit;
  font-weight: bold;
  cursor: pointer;
  border-radius: 1px;
  border: 1px solid #4a4a4a;
  background: linear-gradient(180deg, #3a3a3a 0%, #252525 100%);
  color: #c8c8c8;
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.10), 0 1px 2px rgba(0,0,0,0.5);
  white-space: nowrap;
  transition: filter 0.1s;
}
.bm-db-power:hover { filter: brightness(1.2); }
.bm-db-power:active {
  background: linear-gradient(180deg, #222 0%, #333 100%);
  box-shadow: inset 0 1px 3px rgba(0,0,0,0.6);
}
.bm-db-power.is-on {
  border-color: var(--bm-brand);
  background: linear-gradient(180deg, color-mix(in srgb, var(--bm-brand) 35%, #1a1a1a) 0%, color-mix(in srgb, var(--bm-brand) 15%, #0a0a0a) 100%);
  color: var(--bm-brand);
  box-shadow: inset 0 1px 0 color-mix(in srgb, var(--bm-brand) 30%, transparent), 0 0 4px var(--bm-brand-dim);
}
.bm-db-power.is-on:hover { filter: brightness(1.25); }

/* Status tekst */
.bm-db-status {
  flex: 1;
  font-size: 10px;
  font-weight: normal;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  color: rgba(255,255,255,0.35);
}
.bm-db-status.is-active { color: var(--bm-success); }
.bm-db-status.is-warn   { color: var(--bm-warning); }
.bm-db-status.is-off    { color: var(--bm-text-disabled); }

/* Linia separatora — w kolorze akcentu motywu */
.bm-db-sep {
  height: 1px;
  background: linear-gradient(90deg, transparent, color-mix(in srgb, var(--bm-brand) 55%, transparent) 20%, color-mix(in srgb, var(--bm-brand) 55%, transparent) 80%, transparent);
  margin: 0;
}

/* Wiersz: etykieta po lewej, kontrolka po prawej */
.bm-db-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 4px;
  padding: 0 8px;
  height: 20px;
  line-height: 20px;
  cursor: pointer;
  transition: background 0.08s;
}
.bm-db-row:hover {
  background: var(--bm-brand-dim);
}

/* Etykieta wiersza */
.bm-db-row-lbl {
  flex: 1;
  font-size: 11px;
  font-weight: bold;
  color: var(--bm-text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 20px;
}

/* Checkbox — natywny, accent-color dla zaznaczonego */
.bm-db-chk {
  flex-shrink: 0;
  width: 13px;
  height: 13px;
  margin: 0;
  cursor: pointer;
  accent-color: var(--bm-brand);
}

/* Input numeryczny */
.bm-db-input {
  flex-shrink: 0;
  width: 44px;
  padding: 1px 4px;
  background: #1a1a1a;
  border: 1px solid #555;
  border-radius: 1px;
  color: var(--bm-text-primary);
  font-size: 10px;
  font-family: inherit;
  font-weight: normal;
  text-align: center;
  outline: none;
  box-shadow: inset 0 1px 3px rgba(0,0,0,0.6);
}
.bm-db-input:focus {
  border-color: var(--bm-brand);
  background: #222;
}

/* Select — dropdown */
.bm-db-select {
  flex-shrink: 0;
  padding: 1px 3px;
  background: #1a1a1a;
  border: 1px solid #555;
